{
  "name": "eventiva/craft-synmon",
  "description": "Plugin name: SynMon",
  "type": "craft-plugin",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "craftcms/cms": "^5.5.0",
    "dragonmantank/cron-expression": "^3.3"
  },
  "autoload": {
    "psr-4": {
      "eventiva\\synmon\\": "src/"
    }
  },
  "extra": {
    "handle": "synmon",
    "name": "SynMon",
    "developer": "Eventiva",
    "class": "eventiva\\synmon\\SynMon"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "yiisoft/yii2-composer": true,
      "craftcms/plugin-installer": true
    }
  }
}

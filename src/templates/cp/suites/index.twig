{% extends '_layouts/cp' %}
{% do view.registerAssetBundle('eventiva\\synmon\\assetbundles\\SynMonAssetBundle') %}

{% set title = 'Test Suites'|t('synmon') %}
{% set selectedSubnavItem = 'suites' %}

{% set headerActions = [{
    label: 'New Suite'|t('synmon'),
    url: cpUrl('synmon/suites/new'),
}] %}

{% block content %}

{# Import Form (hidden, triggered by JS) #}
<form id="synmon-import-form" method="post" action="{{ cpUrl('synmon/suites/import') }}" enctype="multipart/form-data" style="display:none">
    {{ csrfInput() }}
    <input type="file" id="synmon-import-file" name="importFile" accept=".json">
</form>

<div style="margin-bottom:16px;text-align:right">
    <button type="button" class="btn" id="btn-import-suite" title="{{ 'Import suite from JSON'|t('synmon') }}">⬆ Import JSON</button>
</div>

{% if suites|length == 0 %}
<div style="text-align:center;padding:60px 0;color:#999">
    <p style="font-size:32px">🔬</p>
    <p>{{ 'No test suites yet.'|t('synmon') }}</p>
    <a href="{{ cpUrl('synmon/suites/new') }}" class="btn submit">{{ 'Create First Suite'|t('synmon') }}</a>
</div>
{% else %}
<table class="data fullwidth synmon-suite-table">
    <thead>
        <tr>
            <th>{{ 'Name'|t('synmon') }}</th>
            <th>{{ 'Cron'|t('synmon') }}</th>
            <th>{{ 'Status'|t('synmon') }}</th>
            <th>{{ 'Active'|t('synmon') }}</th>
            <th>{{ 'Last Run'|t('synmon') }}</th>
            <th>{{ 'Next Run'|t('synmon') }}</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for suite in suites %}
        <tr>
            <td>
                <a href="{{ cpUrl('synmon/suites/' ~ suite.id) }}">{{ suite.name }}</a>
                <span style="font-size:10px;color:#aaa;margin-left:6px">#{{ suite.id }}</span>
                {% if suite.description %}<br><small style="color:#999">{{ suite.description }}</small>{% endif %}
            </td>
            <td><span class="cron-badge">{{ suite.cronExpression }}</span></td>
            <td>
                {% if suite.lastRunStatus %}
                    <span class="synmon-status-badge synmon-status-{{ suite.lastRunStatus }}">{{ suite.lastRunStatus }}</span>
                {% else %}
                    <span style="color:#aaa">—</span>
                {% endif %}
            </td>
            <td>
                <input type="checkbox" class="suite-toggle" data-suite-id="{{ suite.id }}"
                    {{ suite.enabled ? 'checked' : '' }}>
            </td>
            <td>{{ suite.lastRunAt ? suite.lastRunAt|date('d.m.Y H:i') : '—' }}</td>
            <td>
                {% if suite.enabled and nextRuns[suite.id] is defined %}
                    <span style="font-size:12px;color:#374151">{{ nextRuns[suite.id] }}</span>
                {% else %}
                    <span style="color:#aaa;font-size:12px">{{ suite.enabled ? '—' : 'disabled'|t('synmon') }}</span>
                {% endif %}
            </td>
            <td style="text-align:right;white-space:nowrap">
                <button class="btn small btn-run-suite" data-suite-id="{{ suite.id }}" title="{{ 'Test now'|t('synmon') }}">▶ {{ 'Test now'|t('synmon') }}</button>
                <a href="{{ cpUrl('synmon/suites/' ~ suite.id ~ '/live') }}" class="btn small" title="{{ 'Start live test'|t('synmon') }}">🎬 {{ 'Live test'|t('synmon') }}</a>
                <a href="{{ cpUrl('synmon/suites/' ~ suite.id) }}" class="btn small">{{ 'Edit'|t }}</a>
                <a href="{{ cpUrl('synmon/suites/' ~ suite.id ~ '/export') }}" class="btn small" title="{{ 'Export as JSON'|t('synmon') }}">⬇ Export</a>
                <form method="post" style="display:inline" onsubmit="return confirm({{ 'Clone suite?'|t('synmon')|json_encode|raw }})">
                    {{ csrfInput() }}
                    <button type="submit" formaction="{{ cpUrl('synmon/suites/' ~ suite.id ~ '/clone') }}" class="btn small">⎘ {{ 'Clone'|t }}</button>
                </form>
                <form method="post" style="display:inline" onsubmit="return confirm({{ 'Delete suite?'|t('synmon')|json_encode|raw }})">
                    {{ csrfInput() }}
                    <input type="hidden" name="suiteId" value="{{ suite.id }}">
                    <button type="submit" formaction="{{ cpUrl('synmon/suites/delete') }}" class="btn small">✕</button>
                </form>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endif %}

{% js %}
document.getElementById('btn-import-suite').addEventListener('click', function () {
    document.getElementById('synmon-import-file').click();
});
document.getElementById('synmon-import-file').addEventListener('change', function () {
    if (this.files.length > 0) {
        document.getElementById('synmon-import-form').submit();
    }
});
{% endjs %}

{% endblock %}

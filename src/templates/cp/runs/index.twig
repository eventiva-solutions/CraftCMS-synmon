{% extends '_layouts/cp' %}
{% do view.registerAssetBundle('eventiva\\synmon\\assetbundles\\SynMonAssetBundle') %}

{% set title = 'Run History' %}
{% set selectedSubnavItem = 'runs' %}

{% block content %}

<div style="display:flex;gap:10px;margin-bottom:16px;align-items:center;flex-wrap:wrap">
    <form method="get" style="display:flex;gap:8px;flex-wrap:wrap">
        <select name="suiteId" class="select">
            <option value="">Alle Suites</option>
            {% for s in suites %}
                <option value="{{ s.id }}" {{ suiteId == s.id ? 'selected' : '' }}>{{ s.name }}</option>
            {% endfor %}
        </select>
        <select name="status" class="select">
            <option value="">Alle Status</option>
            <option value="pass"    {{ status == 'pass'    ? 'selected' : '' }}>Pass</option>
            <option value="fail"    {{ status == 'fail'    ? 'selected' : '' }}>Fail</option>
            <option value="error"   {{ status == 'error'   ? 'selected' : '' }}>Error</option>
            <option value="running" {{ status == 'running' ? 'selected' : '' }}>Running</option>
        </select>
        <button type="submit" class="btn">Filter</button>
    </form>

    <form method="post" style="margin-left:auto" onsubmit="return confirm('Alte Runs wirklich löschen?')">
        {{ csrfInput() }}
        <input type="hidden" name="days" value="30">
        <button type="submit" formaction="{{ cpUrl('synmon/runs/purge') }}" class="btn">Runs > 30 Tage löschen</button>
    </form>
</div>

<table class="data fullwidth">
    <thead>
        <tr>
            <th>#</th>
            <th>Suite</th>
            <th>Status</th>
            <th>Dauer</th>
            <th>Trigger</th>
            <th>Node</th>
            <th>Datum</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for run in runs %}
        <tr>
            <td><a href="{{ cpUrl('synmon/runs/' ~ run.id) }}">#{{ run.id }}</a></td>
            <td>{{ run.suiteName }}</td>
            <td><span class="synmon-status-badge synmon-status-{{ run.status }}">{{ run.status }}</span></td>
            <td>{{ run.durationMs ? (run.durationMs / 1000)|round(1) ~ 's' : '—' }}</td>
            <td>{{ run.trigger }}</td>
            <td><small>{{ run.nodeVersion ?? '—' }}</small></td>
            <td>{{ run.dateCreated|date('d.m.Y H:i') }}</td>
            <td>
                <form method="post" style="display:inline" onsubmit="return confirm('Run löschen?')">
                    {{ csrfInput() }}
                    <input type="hidden" name="runId" value="{{ run.id }}">
                    <button type="submit" formaction="{{ cpUrl('synmon/runs/delete') }}" class="btn small">Löschen</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="8" style="text-align:center;color:#999;padding:40px">Keine Runs vorhanden.</td></tr>
        {% endfor %}
    </tbody>
</table>

{% if totalPages > 1 %}
<div style="display:flex;gap:8px;margin-top:16px">
    {% if page > 1 %}<a href="?page={{ page-1 }}&suiteId={{ suiteId }}&status={{ status }}" class="btn">← Zurück</a>{% endif %}
    <span style="align-self:center">Seite {{ page }} / {{ totalPages }} ({{ total }} Runs)</span>
    {% if page < totalPages %}<a href="?page={{ page+1 }}&suiteId={{ suiteId }}&status={{ status }}" class="btn">Weiter →</a>{% endif %}
</div>
{% endif %}

{% endblock %}

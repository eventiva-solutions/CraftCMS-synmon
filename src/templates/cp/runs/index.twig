{% extends '_layouts/cp' %}
{% do view.registerAssetBundle('eventiva\\synmon\\assetbundles\\SynMonAssetBundle') %}

{% set title = 'Run History'|t('synmon') %}
{% set selectedSubnavItem = 'runs' %}

{% block content %}

<div style="display:flex;gap:10px;margin-bottom:16px;align-items:center;flex-wrap:wrap">
    <form method="get" style="display:flex;gap:8px;flex-wrap:wrap">
        <select name="suiteId" class="select">
            <option value="">{{ 'All Suites'|t('synmon') }}</option>
            {% for s in suites %}
                <option value="{{ s.id }}" {{ suiteId == s.id ? 'selected' : '' }}>{{ s.name }}</option>
            {% endfor %}
        </select>
        <select name="status" class="select">
            <option value="">{{ 'All Statuses'|t('synmon') }}</option>
            <option value="pass"    {{ status == 'pass'    ? 'selected' : '' }}>Pass</option>
            <option value="fail"    {{ status == 'fail'    ? 'selected' : '' }}>Fail</option>
            <option value="error"   {{ status == 'error'   ? 'selected' : '' }}>Error</option>
            <option value="running" {{ status == 'running' ? 'selected' : '' }}>Running</option>
        </select>
        <button type="submit" class="btn">{{ 'Filter'|t('synmon') }}</button>
    </form>

    <form method="post" style="margin-left:auto" onsubmit="return confirm({{ 'Really delete old runs?'|t('synmon')|json_encode|raw }})">
        {{ csrfInput() }}
        <input type="hidden" name="days" value="30">
        <button type="submit" formaction="{{ cpUrl('synmon/runs/purge') }}" class="btn">{{ 'Delete Runs > 30 days'|t('synmon') }}</button>
    </form>
</div>

<table class="data fullwidth">
    <thead>
        <tr>
            <th>#</th>
            <th>{{ 'Suite'|t('synmon') }}</th>
            <th>{{ 'Status'|t('synmon') }}</th>
            <th>{{ 'Duration'|t('synmon') }}</th>
            <th>{{ 'Trigger'|t('synmon') }}</th>
            <th>{{ 'Node'|t('synmon') }}</th>
            <th>{{ 'Date'|t('synmon') }}</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for run in runs %}
        <tr>
            <td><a href="{{ cpUrl('synmon/runs/' ~ run.id) }}">#{{ run.id }}</a></td>
            <td>{{ run.suiteName }}</td>
            <td><span class="synmon-status-badge synmon-status-{{ run.status }}">{{ run.status }}</span></td>
            <td>{{ run.durationMs ? (run.durationMs / 1000)|round(1) ~ 's' : '—' }}</td>
            <td>{{ run.trigger }}</td>
            <td><small>{{ run.nodeVersion ?? '—' }}</small></td>
            <td>{{ run.dateCreated|date('d.m.Y H:i') }}</td>
            <td>
                <form method="post" style="display:inline" onsubmit="return confirm({{ 'Delete run?'|t('synmon')|json_encode|raw }})">
                    {{ csrfInput() }}
                    <input type="hidden" name="runId" value="{{ run.id }}">
                    <button type="submit" formaction="{{ cpUrl('synmon/runs/delete') }}" class="btn small">{{ 'Delete'|t('synmon') }}</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="8" style="text-align:center;color:#999;padding:40px">{{ 'No runs found.'|t('synmon') }}</td></tr>
        {% endfor %}
    </tbody>
</table>

{% if totalPages > 1 %}
<div style="display:flex;gap:8px;margin-top:16px">
    {% if page > 1 %}<a href="?page={{ page-1 }}&suiteId={{ suiteId }}&status={{ status }}" class="btn">← {{ 'Back'|t('synmon') }}</a>{% endif %}
    <span style="align-self:center">{{ 'Page {page} / {totalPages} ({total} Runs)'|t('synmon', {page: page, totalPages: totalPages, total: total}) }}</span>
    {% if page < totalPages %}<a href="?page={{ page+1 }}&suiteId={{ suiteId }}&status={{ status }}" class="btn">{{ 'Next'|t }} →</a>{% endif %}
</div>
{% endif %}

{% endblock %}
